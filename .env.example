API_HOST=127.0.0.1
API_PORT=8787
API_TOKEN=change-me-to-a-long-random-token
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-different-long-random-secret
SESSION_TTL_HOURS=12
REFRESH_CADENCE_HOURS=12
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://YOUR_GITHUB_USERNAME.github.io
DATA_DIR=./data

# Optional static frontend default. Use a stable HTTPS tunnel/domain for GitHub Pages builds.
VITE_DEFAULT_API_BASE=

# Optional. The data refresh works without model calls.
# Set both variables, then run `npm run refresh:ai` only when you want AI wiki synthesis.
OPENAI_API_KEY=
OPENAI_MODEL=
